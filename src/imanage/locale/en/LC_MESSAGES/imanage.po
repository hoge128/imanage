# --- core.py: argparse help ---
msgid "Photographer Tool"
msgstr "Photographer Tool"

msgid "jpg ディレクトリに存在しない raw ファイルを削除する"
msgstr "Delete RAW files that have no matching JPG in the jpg directory"

msgid "jpg の XMP メタデータを同名 raw ファイルに同期する"
msgstr "Sync XMP metadata from JPG files to their matching RAW files"

msgid "(未使用)"
msgstr "(unused)"

msgid "jpg/raw を作成日時ごとの日付フォルダ (YYYYMMDD/jpg, YYYYMMDD/raw) に仕分ける"
msgstr "Sort jpg/raw files into date folders (YYYYMMDD/jpg, YYYYMMDD/raw) by creation date"

msgid "PATH 配下の jpg/raw 構造を持つすべてのディレクトリに -s を適用する"
msgstr "Apply -s to all directories with a jpg/raw structure under PATH"

msgid "ペアの RAW から DateTimeOriginal/Digitized を JPG EXIF に復元する（2026-04-25 以前に imanage を適用したファイルの修復用）"
msgstr "Restore DateTimeOriginal/Digitized from paired RAW to JPG EXIF (for files processed by imanage before 2026-04-25)"

msgid "エラーのみ出力する（スクリプト用）"
msgstr "Output errors only (for scripting)"

msgid "ファイル単位の処理詳細も表示する"
msgstr "Show per-file processing details"

msgid "ログをファイルに出力する（PATH 省略時: ~/.local/state/imanage/imanage.log）"
msgstr "Write log to file (default path when PATH omitted: ~/.local/state/imanage/imanage.log)"

msgid "config の destination 配下に整理する（DEST 指定で上書き）"
msgstr "Organize into config destination (override with DEST)"

msgid "cwd 配下を再帰的に destination 配下へ整理する（DEST 指定で上書き）"
msgstr "Recursively organize cwd into destination (override with DEST)"

msgid "cwd 配下を再帰的に各ディレクトリ内で整理する（in-place。初回の取り込み時に使用を推奨）"
msgstr "Recursively organize cwd in-place within each directory (recommended for initial import)"

msgid "メタデータが未適用のファイルに XMP を書き込む"
msgstr "Write XMP to files that have not yet had metadata applied"

msgid "XMP メタデータを書き込む（デフォルトは無効）"
msgstr "Write XMP metadata (disabled by default)"

msgid "XMP サイドカーを raw/ と jpg/ のどちらに振り分けるか（config を上書き、デフォルト: raw）"
msgstr "Which directory to place XMP sidecars in: raw/ or jpg/ (overrides config, default: raw)"

msgid "直前の操作を取り消す"
msgstr "Undo the last operation"

msgid "確認プロンプトをスキップして即実行する"
msgstr "Skip confirmation prompt and execute immediately"

