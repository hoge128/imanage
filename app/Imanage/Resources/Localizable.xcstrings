    "jpg / raw / retouch などファイル種別ごとにサブフォルダへ分けます（EXIF ではなく拡張子で判定）。": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "jpg / raw / retouch などファイル種別ごとにサブフォルダへ分けます（EXIF ではなく拡張子で判定）。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Splits files into subfolders by file type, such as jpg / raw / retouch (decided by extension, not EXIF)."
          }
        }
      }
    },
