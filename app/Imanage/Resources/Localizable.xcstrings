        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Automatically sorts photos into folders based on their EXIF capture date.\nRAW+JPG pairs and XMP sidecars move together,\nand you can preview the result before organizing."
          }
        },
        "ja": {
          "stringUnit": {
