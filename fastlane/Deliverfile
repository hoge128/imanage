# fastlane deliver config — Imanage (Mac App Store)
# https://docs.fastlane.tools/actions/deliver/
#
# メタデータ（日英）とスクリーンショットを git 管理し、ASC へ投入する設定。
# バイナリ（.pkg）は Xcode Archive → Distribute → App Store Connect で
# アップロードする運用なので、ここでは skip_binary_upload(true)。

app_identifier("com.itotsum.imanage")
platform("osx")

# --- バイナリ ---
# Xcode 側でアップロードするためスキップ。
skip_binary_upload(true)

# --- メタデータ / スクショ ---
metadata_path("./fastlane/metadata")
screenshots_path("./fastlane/screenshots")

# ローカルのファイルを正として ASC を上書きする（= git が単一の真実）。
overwrite_screenshots(true)

# --- レビュー提出 ---
# 自動提出はしない。内容を ASC で目視確認してから手動で提出する。
submit_for_review(false)

# HTML プレビュー確認をスキップして非対話で実行（--force と等価）。
force(true)

# precheck（規約違反の事前チェック）を走らせる。
run_precheck_before_submit(true)
